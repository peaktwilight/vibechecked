---
import Layout from '../layouts/Layout.astro';
import { Camera, Search, Flame, Palette, Layout as LayoutIcon, Type, Droplets, ShieldAlert, Sparkles, Star, ExternalLink, ChevronDown, Copy, Check, Share2, Layers, Grid3x3, Smartphone, Moon, Circle, Fingerprint, Award } from '@lucide/astro';

const scores = [
  { label: 'Originality', value: 62, color: '#eab308' },
  { label: 'Layout', value: 35, color: '#ef4444' },
  { label: 'Typography', value: 55, color: '#eab308' },
  { label: 'Color', value: 58, color: '#eab308' },
  { label: 'Overall', value: 50, color: '#eab308' },
];

const redFlags = [
  { label: 'Purple gradients', icon: 'palette' },
  { label: 'Glassmorphism', icon: 'layers' },
  { label: 'Hero > Features > Pricing layout', icon: 'layout' },
  { label: 'Gradient text', icon: 'type' },
  { label: '"Trusted by" logo bars', icon: 'award' },
  { label: '3-column feature cards', icon: 'grid' },
  { label: 'Floating angled mockups', icon: 'smartphone' },
  { label: 'Dark mode + neon accents', icon: 'moon' },
  { label: 'Excessive rounded corners', icon: 'circle' },
];

const roasts = [
  {
    site: "vibechecked.doruk.ch",
    label: "Us. We roasted ourselves.",
    score: 49,
    verdict: "KINDA MID",
    probability: 68,
    roast: "You built a tool to roast vibe-coded sites and then vibe-coded the landing page. It's like a barber with a bad haircut.",
    scores: { originality: 62, layout: 35, typography: 58, color: 52 },
    verdictColor: "#eab308",
    selfRoast: true,
  },
  {
    site: "generic-saas-template.vercel.app",
    label: "Every SaaS template ever",
    score: 18,
    verdict: "VIBE-CODED CLONE",
    probability: 95,
    roast: "Purple gradient hero, glassmorphism pricing cards, 'Trusted by 10,000+ companies' with logos you've never heard of. This template has been forked 47,000 times and it shows.",
    scores: { originality: 5, layout: 10, typography: 30, color: 15 },
    verdictColor: "#ef4444",
  },
  {
    site: "ai-wrapper-starter.netlify.app",
    label: "The ChatGPT wrapper starter kit",
    score: 22,
    verdict: "VIBE-CODED CLONE",
    probability: 92,
    roast: "Dark mode, neon accent, chat interface on the right, 'Powered by AI' badge. You didn't build a product, you installed a template and changed the logo.",
    scores: { originality: 10, layout: 15, typography: 35, color: 20 },
    verdictColor: "#ef4444",
  },
  {
    site: "my-side-project.vercel.app",
    label: "Every indie hacker landing page",
    score: 35,
    verdict: "GENERIC AF",
    probability: 75,
    roast: "Hero section with your face, 'I built this in a weekend' energy, three feature cards with Lucide icons, and a 'Star on GitHub' button that's doing all the emotional heavy lifting.",
    scores: { originality: 25, layout: 20, typography: 45, color: 40 },
    verdictColor: "#f97316",
  },
  {
    site: "startup-landing.framer.app",
    label: "The Framer template special",
    score: 42,
    verdict: "GENERIC AF",
    probability: 60,
    roast: "Beautiful animations, gorgeous typography, zero original thought. This is what happens when your entire design process is 'pick a Framer template and change the colors.'",
    scores: { originality: 30, layout: 40, typography: 65, color: 35 },
    verdictColor: "#f97316",
  },
  {
    site: "hand-crafted-portfolio.dev",
    label: "The rare handcrafted site",
    score: 88,
    verdict: "CERTIFIED ORIGINAL",
    probability: 5,
    roast: "Wait — someone actually designed this themselves? Custom layout, thoughtful color choices, typography that wasn't picked by an AI. We didn't think these existed anymore.",
    scores: { originality: 92, layout: 85, typography: 90, color: 82 },
    verdictColor: "#22c55e",
  },
];

const verdicts = [
  { label: 'CERTIFIED ORIGINAL', color: '#22c55e', bg: '#22c55e15', border: '#22c55e40' },
  { label: 'MOSTLY FRESH', color: '#86efac', bg: '#86efac15', border: '#86efac40' },
  { label: 'KINDA MID', color: '#eab308', bg: '#eab30815', border: '#eab30840' },
  { label: 'GENERIC AF', color: '#f97316', bg: '#f9731615', border: '#f9731640' },
  { label: 'VIBE-CODED CLONE', color: '#ef4444', bg: '#ef444415', border: '#ef444440' },
];
---

<Layout>
  <!-- ═══════════════ NAVBAR ═══════════════ -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
      <a href="/" class="font-mono text-lg font-bold text-white tracking-tight">
        vibe<span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-500">checked</span>
      </a>
      <a
        href="https://github.com/peaktwilight/vibechecked"
        target="_blank"
        rel="noopener"
        class="text-gray-400 hover:text-white transition-colors"
        aria-label="GitHub"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
    </div>
  </nav>
  <script>
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        navbar?.classList.add('bg-[#0a0a0a]/80', 'backdrop-blur-md', 'border-b', 'border-gray-800/50');
      } else {
        navbar?.classList.remove('bg-[#0a0a0a]/80', 'backdrop-blur-md', 'border-b', 'border-gray-800/50');
      }
    }, { passive: true });
  </script>

  <div class="noise">
    <!-- ═══════════════ HERO ═══════════════ -->
    <section class="relative min-h-screen flex flex-col items-center justify-center px-4 overflow-hidden">
      <!-- Subtle grid background -->
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(#22c55e 1px, transparent 1px), linear-gradient(90deg, #22c55e 1px, transparent 1px); background-size: 60px 60px;"></div>

      <!-- Glow effect -->
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-green-accent/5 rounded-full blur-[120px]"></div>

      <div class="relative z-10 text-center max-w-4xl mx-auto">
        <!-- Logo -->
        <h1 class="font-mono text-6xl sm:text-7xl md:text-8xl font-bold tracking-tighter text-white mb-4 animate-fade-in-up">
          vibe<span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-500">checked</span>
        </h1>

        <!-- Tagline with pulsing dot -->
        <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-12 animate-fade-in-up delay-200 font-sans flex items-center justify-center gap-2">
          <span class="relative flex h-2.5 w-2.5 shrink-0">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-accent opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-accent"></span>
          </span>
          The only design review that doesn't care about your feelings.
        </p>

        <div class="animate-fade-in-up delay-300 mb-8">
          <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-green-accent/10 border border-green-accent/20 rounded-full text-green-accent text-xs font-mono">
            100% vibe-coded
          </span>
        </div>

        <!-- Terminal -->
        <div class="animate-fade-in-up delay-400 w-full max-w-2xl mx-auto">
          <div class="rounded-xl border border-gray-800 bg-[#111111] shadow-2xl shadow-black/50 overflow-hidden text-left">
            <!-- Terminal header -->
            <div class="flex items-center gap-2 px-4 py-2.5 bg-[#0d0d0d] border-b border-gray-800">
              <div class="flex items-center gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></div>
              </div>
              <div class="flex-1 mx-8">
                <div class="bg-[#1a1a1a] rounded-md px-3 py-1 text-center">
                  <span class="text-[10px] text-gray-500 font-mono">npx vibechecked vercel.com</span>
                </div>
              </div>
              <div class="w-[52px]"></div>
            </div>

            <!-- Terminal body -->
            <div class="p-3 sm:p-6 font-mono text-[11px] sm:text-sm leading-relaxed space-y-3">
              <!-- Command -->
              <div class="terminal-line text-gray-500" style="animation-delay: 0.3s;">
                <span class="text-green-accent">$</span> npx vibechecked vercel.com
              </div>

              <div class="terminal-line text-gray-600 text-xs" style="animation-delay: 0.6s;">Analyzing screenshot...</div>

              <!-- Score bars -->
              <div class="space-y-2 pt-2">
                {scores.map((score, i) => (
                  <div class="terminal-line flex items-center gap-3" style={`animation-delay: ${0.8 + i * 0.2}s;`}>
                    <span class="text-gray-500 text-xs w-16 sm:w-24 text-right">{score.label}</span>
                    <div class="flex-1 h-4 bg-gray-800/50 rounded-sm overflow-hidden relative">
                      <div
                        class="h-full rounded-sm animate-fill-bar"
                        style={`width: ${score.value}%; background: ${score.color}; animation-delay: ${0.8 + i * 0.2}s;`}
                      ></div>
                    </div>
                    <span class="text-xs w-8" style={`color: ${score.color}`}>{score.value}</span>
                  </div>
                ))}
              </div>

              <!-- Roast -->
              <div class="terminal-line pt-3 border-t border-gray-800/50" style="animation-delay: 2s;">
                <span class="text-gray-600 text-xs">ROAST:</span>
                <p class="text-gray-300 text-xs mt-1 leading-relaxed animate-roast">
                  "Vercel really said 'we're the AI Cloud' and then slapped a triangle on a rainbow gradient like a Pink Floyd album cover designed by a CS major who just discovered CSS blend modes."
                </p>
              </div>

              <!-- Verdict -->
              <div class="terminal-line flex items-center gap-3 pt-2" style="animation-delay: 2.5s;">
                <span class="text-gray-600 text-xs">VERDICT:</span>
                <span class="text-yellow-400 font-bold text-sm tracking-wider">KINDA MID</span>
              </div>

              <!-- Vibe-coded probability -->
              <div class="terminal-line flex items-center gap-3" style="animation-delay: 2.8s;">
                <span class="text-gray-600 text-xs">VIBE-CODED:</span>
                <span class="text-yellow-400 text-sm">38%</span>
                <div class="flex-1 h-1.5 bg-gray-800 rounded-full overflow-hidden">
                  <div class="h-full bg-yellow-400/60 rounded-full animate-fill-bar" style="width: 38%; animation-delay: 2.8s;"></div>
                </div>
              </div>

              <!-- Cursor -->
              <div class="terminal-line pt-1" style="animation-delay: 3s;">
                <span class="text-green-accent">$</span>
                <span class="inline-block w-2 h-4 bg-green-accent ml-1 animate-blink"></span>
              </div>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="mt-10 animate-fade-in-up delay-700">
          <a
            href="https://github.com/peaktwilight/vibechecked"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 bg-green-accent text-[#0a0a0a] font-mono font-semibold text-sm rounded-md hover:bg-green-400 transition-colors duration-200"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            Get Started
          </a>
        </div>

        <!-- GitHub star line -->
        <p class="text-gray-500 font-mono text-sm mt-4 animate-fade-in-up delay-800 flex items-center justify-center gap-2">
          <a href="https://github.com/peaktwilight/vibechecked" target="_blank" rel="noopener" class="hover:text-green-accent transition-colors inline-flex items-center gap-1">
            <Star class="w-3.5 h-3.5" />
            Star on GitHub
          </a>
          <span>&middot;</span>
          <span>Free &amp; open source</span>
          <span>&middot;</span>
          <span>MIT License</span>
        </p>
      </div>

      <!-- Scroll indicator -->
      <a href="#try-it" class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce opacity-30 cursor-pointer">
        <ChevronDown class="w-5 h-5 text-gray-500" />
      </a>
    </section>

    <!-- ═══════════════ TRY IT ═══════════════ -->
    <section id="try-it" class="relative py-24 px-4">
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-8">
          <h2 class="font-mono text-3xl sm:text-4xl font-bold text-white mb-4">
            Think YOUR site would <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-500">pass</span>?
          </h2>
          <p class="text-gray-500 text-sm">Paste a URL and get an instant vibe check.</p>
        </div>

        <!-- Input form -->
        <div class="flex gap-2 mb-2">
          <input
            type="url"
            id="url-input"
            placeholder="https://your-app.vercel.app"
            class="bg-[#111] border border-gray-800 rounded-lg px-4 py-3 font-mono text-sm flex-1 focus:border-green-accent focus:outline-none text-gray-200 placeholder:text-gray-600"
          />
          <button
            id="check-btn"
            class="bg-green-accent text-black font-mono font-bold px-6 py-3 rounded-lg hover:bg-green-400 transition-colors cursor-pointer shrink-0 flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span id="btn-text">Check Vibe</span>
            <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
        </div>

        <!-- Loading state -->
        <div id="loading-state" class="hidden mt-8">
          <div class="rounded-xl border border-gray-800 bg-[#111111] overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-2.5 bg-[#0d0d0d] border-b border-gray-800">
              <div class="flex items-center gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></div>
              </div>
              <div class="flex-1 mx-8">
                <div class="bg-[#1a1a1a] rounded-md px-3 py-1 text-center">
                  <span class="text-[10px] text-gray-500 font-mono" id="loading-url">analyzing...</span>
                </div>
              </div>
            </div>
            <div class="p-6 font-mono text-sm text-center">
              <div class="flex flex-col items-center gap-3">
                <svg class="w-8 h-8 animate-spin text-green-accent" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <div class="space-y-1">
                  <p class="text-gray-400 text-xs" id="loading-step">Capturing screenshot...</p>
                  <p class="text-gray-600 text-[10px]">Running AI analysis</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Results card -->
        <div id="results-card" class="hidden mt-8">
          <div class="rounded-xl border border-gray-800 bg-[#111111] shadow-2xl shadow-black/50 overflow-hidden">
            <!-- Terminal header -->
            <div class="flex items-center gap-2 px-4 py-2.5 bg-[#0d0d0d] border-b border-gray-800">
              <div class="flex items-center gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></div>
              </div>
              <div class="flex-1 mx-8">
                <div class="bg-[#1a1a1a] rounded-md px-3 py-1 text-center">
                  <span class="text-[10px] text-gray-500 font-mono" id="result-url-header">vibechecked</span>
                </div>
              </div>
              <div class="w-[52px]"></div>
            </div>

            <!-- Terminal body -->
            <div class="p-3 sm:p-6 font-mono text-[11px] sm:text-sm leading-relaxed space-y-3">
              <!-- Command echo -->
              <div class="text-gray-500">
                <span class="text-green-accent">$</span> npx vibechecked <span id="result-url-echo" class="text-gray-300"></span>
              </div>

              <!-- Screenshot preview -->
              <div id="screenshot-wrap" class="hidden rounded-lg overflow-hidden border border-gray-800 mb-2">
                <img id="screenshot-img" class="w-full h-auto" alt="Screenshot preview" />
              </div>

              <!-- Score bars -->
              <div class="space-y-2 pt-2" id="score-bars"></div>

              <!-- Roast -->
              <div class="pt-3 border-t border-gray-800/50">
                <span class="text-gray-600 text-xs">ROAST:</span>
                <p class="text-gray-300 text-xs mt-1 leading-relaxed italic" id="result-roast"></p>
              </div>

              <!-- Verdict -->
              <div class="flex items-center gap-3 pt-2">
                <span class="text-gray-600 text-xs">VERDICT:</span>
                <span class="font-bold text-sm tracking-wider" id="result-verdict"></span>
              </div>

              <!-- Vibe-coded probability -->
              <div class="flex items-center gap-3">
                <span class="text-gray-600 text-xs">VIBE-CODED:</span>
                <span class="text-sm" id="result-probability"></span>
                <div class="flex-1 h-1.5 bg-gray-800 rounded-full overflow-hidden">
                  <div class="h-full rounded-full transition-all duration-1000 ease-out" id="result-probability-bar" style="width: 0%"></div>
                </div>
              </div>

              <!-- Red flags -->
              <div class="pt-2 border-t border-gray-800/50">
                <span class="text-gray-600 text-xs">RED FLAGS:</span>
                <div class="flex flex-wrap gap-1.5 mt-1.5" id="result-flags"></div>
              </div>

              <!-- Cursor -->
              <div class="pt-1">
                <span class="text-green-accent">$</span>
                <span class="inline-block w-2 h-4 bg-green-accent ml-1 animate-blink"></span>
              </div>
            </div>

            <!-- Disclaimer bar -->
            <div class="px-4 sm:px-6 py-3 bg-[#0d0d0d] border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-2">
              <p class="text-[10px] text-gray-600 font-mono">
                Demo preview with simulated scores. Install the CLI for real AI-powered analysis.
              </p>
              <code class="text-[10px] text-green-accent font-mono bg-green-accent/10 px-2 py-0.5 rounded">npx vibechecked &lt;url&gt;</code>
            </div>
          </div>
        </div>
      </div>
    </section>

    <script>
    (function() {
      // --- Deterministic hash from string ---
      function hashStr(str) {
        let h = 0;
        for (let i = 0; i < str.length; i++) {
          h = ((h << 5) - h + str.charCodeAt(i)) | 0;
        }
        return Math.abs(h);
      }

      // --- Seeded pseudo-random (mulberry32) ---
      function seededRandom(seed) {
        let s = seed;
        return function() {
          s |= 0; s = (s + 0x6D2B79F5) | 0;
          let t = Math.imul(s ^ (s >>> 15), 1 | s);
          t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
          return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
        };
      }

      // --- Generate mock results from URL ---
      function generateResults(url) {
        const seed = hashStr(url);
        const rand = seededRandom(seed);

        const originality = Math.floor(rand() * 60 + 20);
        const layout = Math.floor(rand() * 60 + 15);
        const typography = Math.floor(rand() * 55 + 25);
        const color = Math.floor(rand() * 55 + 25);
        const overall = Math.floor((originality + layout + typography + color) / 4);
        const probability = Math.floor(rand() * 70 + 10);

        const scores = [
          { label: 'Originality', value: originality },
          { label: 'Layout', value: layout },
          { label: 'Typography', value: typography },
          { label: 'Color', value: color },
          { label: 'Overall', value: overall },
        ];

        let verdict, verdictColor;
        if (overall >= 75) { verdict = 'CERTIFIED ORIGINAL'; verdictColor = '#22c55e'; }
        else if (overall >= 60) { verdict = 'MOSTLY FRESH'; verdictColor = '#86efac'; }
        else if (overall >= 45) { verdict = 'KINDA MID'; verdictColor = '#eab308'; }
        else if (overall >= 30) { verdict = 'GENERIC AF'; verdictColor = '#f97316'; }
        else { verdict = 'VIBE-CODED CLONE'; verdictColor = '#ef4444'; }

        const allFlags = [
          'Purple gradients', 'Glassmorphism', 'Hero > Features > Pricing',
          'Gradient text', '"Trusted by" logo bars', '3-column feature cards',
          'Floating angled mockups', 'Dark mode + neon accents', 'Excessive rounded corners',
          'Stock illustrations', 'Infinite scroll'
        ];
        const flagCount = Math.floor(rand() * 4 + 1);
        const flags = [];
        const shuffled = [...allFlags];
        for (let i = shuffled.length - 1; i > 0; i--) {
          const j = Math.floor(rand() * (i + 1));
          [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
        }
        for (let i = 0; i < flagCount; i++) flags.push(shuffled[i]);

        const domain = url.replace(/^https?:\/\//, '').replace(/\/.*$/, '');
        const roasts = [
          `"${domain} really said 'we're different' and then shipped the exact same Hero > CTA > scroll-forever layout as every other site on Product Hunt this week."`,
          `"${domain} looks like someone typed 'modern SaaS landing page' into an AI image generator and then recreated it pixel by pixel in Tailwind."`,
          `"${domain} has that 'I watched one YouTube tutorial on web design and now I'm a senior designer' energy. The gradients are doing a lot of heavy lifting here."`,
          `"${domain} is what happens when you tell an AI to make a landing page and then never question any of its decisions. Bold strategy."`,
          `"${domain} proves that with enough drop shadows and rounded corners, you can make absolutely anything look like a fintech startup."`,
          `"${domain} screams 'we spent more time on the gradient than on the value proposition.' The hero section alone has more CSS than some entire applications."`,
          `"${domain} — where every section break is a gradient divider and every icon is from the same Lucide pack. At least be inconsistent about it."`,
        ];
        const roastIdx = Math.floor(rand() * roasts.length);

        return { scores, verdict, verdictColor, probability, flags, roast: roasts[roastIdx] };
      }

      function scoreColor(val) {
        if (val >= 70) return '#22c55e';
        if (val >= 50) return '#eab308';
        return '#ef4444';
      }

      function normalizeUrl(input) {
        let url = input.trim();
        if (!url) return null;
        if (!/^https?:\/\//i.test(url)) url = 'https://' + url;
        try { new URL(url); } catch { return null; }
        return url;
      }

      const urlInput = document.getElementById('url-input');
      const checkBtn = document.getElementById('check-btn');
      const btnText = document.getElementById('btn-text');
      const btnSpinner = document.getElementById('btn-spinner');
      const loadingState = document.getElementById('loading-state');
      const loadingUrl = document.getElementById('loading-url');
      const loadingStep = document.getElementById('loading-step');
      const resultsCard = document.getElementById('results-card');

      async function runCheck() {
        const url = normalizeUrl(urlInput.value);
        if (!url) {
          urlInput.style.borderColor = '#ef4444';
          setTimeout(() => urlInput.style.borderColor = '', 1500);
          return;
        }

        // Show loading
        checkBtn.disabled = true;
        btnText.textContent = 'Checking...';
        btnSpinner.classList.remove('hidden');
        resultsCard.classList.add('hidden');
        loadingState.classList.remove('hidden');
        loadingUrl.textContent = url.replace(/^https?:\/\//, '');

        const steps = ['Capturing screenshot...', 'Analyzing layout patterns...', 'Detecting red flags...', 'Generating roast...'];
        let stepIdx = 0;
        const stepInterval = setInterval(() => {
          stepIdx++;
          if (stepIdx < steps.length) loadingStep.textContent = steps[stepIdx];
        }, 600);

        // Try to load screenshot
        const domain = url.replace(/^https?:\/\//, '').replace(/\/.*$/, '');
        const screenshotUrl = 'https://image.thum.io/get/width/1440/crop/900/' + url;

        // Wait for "analysis" (simulated delay)
        await new Promise(r => setTimeout(r, 2400));
        clearInterval(stepInterval);

        // Generate results
        const results = generateResults(url);

        // Hide loading, show results
        loadingState.classList.add('hidden');

        // Populate results
        document.getElementById('result-url-header').textContent = domain;
        document.getElementById('result-url-echo').textContent = url;

        // Screenshot
        const ssWrap = document.getElementById('screenshot-wrap');
        const ssImg = document.getElementById('screenshot-img');
        ssImg.src = screenshotUrl;
        ssImg.onerror = () => ssWrap.classList.add('hidden');
        ssImg.onload = () => ssWrap.classList.remove('hidden');
        ssWrap.classList.remove('hidden');

        // Score bars (animated)
        const scoreBars = document.getElementById('score-bars');
        scoreBars.innerHTML = '';
        results.scores.forEach((s, i) => {
          const row = document.createElement('div');
          row.className = 'flex items-center gap-3';
          row.style.opacity = '0';
          row.style.transform = 'translateY(4px)';
          row.style.transition = `opacity 0.3s ease ${i * 0.12}s, transform 0.3s ease ${i * 0.12}s`;
          const c = scoreColor(s.value);
          row.innerHTML = `
            <span class="text-gray-500 text-xs w-16 sm:w-24 text-right">${s.label}</span>
            <div class="flex-1 h-4 bg-gray-800/50 rounded-sm overflow-hidden">
              <div class="h-full rounded-sm transition-all duration-1000 ease-out" style="width: 0%; background: ${c};" data-target-width="${s.value}%"></div>
            </div>
            <span class="text-xs w-8" style="color: ${c}">${s.value}</span>
          `;
          scoreBars.appendChild(row);
        });

        // Roast
        document.getElementById('result-roast').textContent = results.roast;

        // Verdict
        const verdictEl = document.getElementById('result-verdict');
        verdictEl.textContent = results.verdict;
        verdictEl.style.color = results.verdictColor;

        // Probability
        const probEl = document.getElementById('result-probability');
        probEl.textContent = results.probability + '%';
        probEl.style.color = results.verdictColor;
        const probBar = document.getElementById('result-probability-bar');
        probBar.style.width = '0%';
        probBar.style.background = results.verdictColor + '99';

        // Flags
        const flagsEl = document.getElementById('result-flags');
        flagsEl.innerHTML = '';
        results.flags.forEach(f => {
          const tag = document.createElement('span');
          tag.className = 'inline-flex items-center px-2 py-0.5 rounded bg-red-500/10 border border-red-500/20 text-red-400 text-[10px] font-mono';
          tag.textContent = f;
          flagsEl.appendChild(tag);
        });

        // Show card
        resultsCard.classList.remove('hidden');

        // Trigger animations after paint
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            scoreBars.querySelectorAll('[data-target-width]').forEach(bar => {
              bar.style.width = bar.dataset.targetWidth;
            });
            scoreBars.querySelectorAll('.flex.items-center').forEach(row => {
              row.style.opacity = '1';
              row.style.transform = 'translateY(0)';
            });
            probBar.style.width = results.probability + '%';
          });
        });

        // Reset button
        checkBtn.disabled = false;
        btnText.textContent = 'Check Vibe';
        btnSpinner.classList.add('hidden');
      }

      checkBtn?.addEventListener('click', runCheck);
      urlInput?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') runCheck();
      });
    })();
    </script>

