---
import Layout from '../layouts/Layout.astro';

const scores = [
  { label: 'Originality', value: 62, color: '#eab308' },
  { label: 'Layout', value: 35, color: '#ef4444' },
  { label: 'Typography', value: 55, color: '#eab308' },
  { label: 'Color', value: 58, color: '#eab308' },
  { label: 'Overall', value: 50, color: '#eab308' },
];

const redFlags = [
  { icon: '🟣', label: 'Purple gradients' },
  { icon: '🪟', label: 'Glassmorphism' },
  { icon: '📐', label: 'Hero > Features > Pricing layout' },
  { icon: '🌈', label: 'Gradient text' },
  { icon: '🏢', label: '"Trusted by" logo bars' },
  { icon: '🃏', label: '3-column feature cards' },
  { icon: '📱', label: 'Floating angled mockups' },
  { icon: '🌙', label: 'Dark mode + neon accents' },
  { icon: '⭕', label: 'Excessive rounded corners' },
];

const verdicts = [
  { label: 'CERTIFIED ORIGINAL', color: '#22c55e', bg: '#22c55e15', border: '#22c55e40' },
  { label: 'MOSTLY FRESH', color: '#86efac', bg: '#86efac15', border: '#86efac40' },
  { label: 'KINDA MID', color: '#eab308', bg: '#eab30815', border: '#eab30840' },
  { label: 'GENERIC AF', color: '#f97316', bg: '#f9731615', border: '#f9731640' },
  { label: 'VIBE-CODED CLONE', color: '#ef4444', bg: '#ef444415', border: '#ef444440' },
];

const steps = [
  { num: '01', title: 'Screenshot', desc: 'Point it at any URL. Puppeteer captures a full-page screenshot.', icon: '📸' },
  { num: '02', title: 'Analyze', desc: 'Claude examines every pixel for design patterns, cliches, and red flags.', icon: '🔍' },
  { num: '03', title: 'Roast', desc: 'Get brutally honest scores, a roast, and your vibe-coded probability.', icon: '🔥' },
];
---

<Layout>
  <!-- ═══════════════ NAVBAR ═══════════════ -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
      <a href="/" class="font-mono text-lg font-bold text-white tracking-tight">
        vibe<span class="text-green-accent">check</span>
      </a>
      <a
        href="https://github.com/peaktwilight/vibecheck"
        target="_blank"
        rel="noopener"
        class="text-gray-400 hover:text-white transition-colors"
        aria-label="GitHub"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
    </div>
  </nav>
  <script>
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        navbar?.classList.add('bg-[#0a0a0a]/80', 'backdrop-blur-md', 'border-b', 'border-gray-800/50');
      } else {
        navbar?.classList.remove('bg-[#0a0a0a]/80', 'backdrop-blur-md', 'border-b', 'border-gray-800/50');
      }
    }, { passive: true });
  </script>

  <div class="noise">
    <!-- ═══════════════ HERO ═══════════════ -->
    <section class="relative min-h-screen flex flex-col items-center justify-center px-4 overflow-hidden">
      <!-- Subtle grid background -->
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(#22c55e 1px, transparent 1px), linear-gradient(90deg, #22c55e 1px, transparent 1px); background-size: 60px 60px;"></div>

      <!-- Glow effect -->
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-green-accent/5 rounded-full blur-[120px]"></div>

      <div class="relative z-10 text-center max-w-4xl mx-auto">
        <!-- Logo -->
        <h1 class="font-mono text-6xl sm:text-7xl md:text-8xl font-bold tracking-tighter text-white mb-4 animate-fade-in-up">
          vibe<span class="text-green-accent">check</span>
        </h1>

        <!-- Tagline -->
        <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-12 animate-fade-in-up delay-200 font-sans">
          Is your UI actually good? Or just another vibe-coded clone?
        </p>

        <!-- Terminal -->
        <div class="animate-fade-in-up delay-400 w-full max-w-2xl mx-auto">
          <div class="rounded-lg border border-gray-800 bg-[#111111] shadow-2xl shadow-black/50 overflow-hidden text-left">
            <!-- Terminal header -->
            <div class="flex items-center gap-2 px-4 py-3 bg-[#0d0d0d] border-b border-gray-800">
              <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
              <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
              <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
              <span class="ml-2 text-xs text-gray-500 font-mono">vibecheck vercel.com</span>
            </div>

            <!-- Terminal body -->
            <div class="p-4 sm:p-6 font-mono text-sm leading-relaxed space-y-3">
              <!-- Command -->
              <div class="text-gray-500">
                <span class="text-green-accent">$</span> vibecheck vercel.com
              </div>

              <div class="text-gray-600 text-xs">Analyzing screenshot...</div>

              <!-- Score bars -->
              <div class="space-y-2 pt-2">
                {scores.map((score, i) => (
                  <div class="flex items-center gap-3">
                    <span class="text-gray-500 text-xs w-24 text-right">{score.label}</span>
                    <div class="flex-1 h-4 bg-gray-800/50 rounded-sm overflow-hidden relative">
                      <div
                        class="h-full rounded-sm animate-fill-bar"
                        style={`width: ${score.value}%; background: ${score.color}; animation-delay: ${0.8 + i * 0.2}s;`}
                      ></div>
                    </div>
                    <span class="text-xs w-8" style={`color: ${score.color}`}>{score.value}</span>
                  </div>
                ))}
              </div>

              <!-- Roast -->
              <div class="pt-3 border-t border-gray-800/50">
                <span class="text-gray-600 text-xs">ROAST:</span>
                <p class="text-gray-300 text-xs mt-1 leading-relaxed">
                  "Vercel really said 'we're the AI Cloud' and then slapped a triangle on a rainbow gradient like a Pink Floyd album cover designed by a CS major who just discovered CSS blend modes."
                </p>
              </div>

              <!-- Verdict -->
              <div class="flex items-center gap-3 pt-2">
                <span class="text-gray-600 text-xs">VERDICT:</span>
                <span class="text-yellow-400 font-bold text-sm tracking-wider">KINDA MID</span>
              </div>

              <!-- Vibe-coded probability -->
              <div class="flex items-center gap-3">
                <span class="text-gray-600 text-xs">VIBE-CODED:</span>
                <span class="text-yellow-400 text-sm">38%</span>
                <div class="flex-1 h-1.5 bg-gray-800 rounded-full overflow-hidden">
                  <div class="h-full bg-yellow-400/60 rounded-full animate-fill-bar" style="width: 38%; animation-delay: 2s;"></div>
                </div>
              </div>

              <!-- Cursor -->
              <div class="pt-1">
                <span class="text-green-accent">$</span>
                <span class="inline-block w-2 h-4 bg-green-accent ml-1 animate-blink"></span>
              </div>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="mt-10 animate-fade-in-up delay-700">
          <a
            href="https://github.com/peaktwilight/vibecheck"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 bg-green-accent text-[#0a0a0a] font-mono font-semibold text-sm rounded-md hover:bg-green-400 transition-colors duration-200"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            Get Started
          </a>
        </div>

        <!-- GitHub star line -->
        <p class="text-gray-500 font-mono text-sm mt-4 animate-fade-in-up delay-800">
          <a href="https://github.com/peaktwilight/vibecheck" target="_blank" rel="noopener" class="hover:text-green-accent transition-colors">
            Star on GitHub
          </a>
          <span class="mx-2">&middot;</span>
          <span>Free &amp; open source</span>
          <span class="mx-2">&middot;</span>
          <span>MIT License</span>
        </p>
      </div>

      <!-- Scroll indicator -->
      <a href="#try-it" class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce opacity-30 cursor-pointer">
        <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
      </a>
    </section>

    <!-- ═══════════════ TRY IT ═══════════════ -->
    <section id="try-it" class="relative py-24 px-4">
      <div class="max-w-xl mx-auto text-center">
        <h2 class="font-mono text-3xl sm:text-4xl font-bold text-white mb-6">
          Think YOUR site would <span class="text-green-accent">pass</span>?
        </h2>
        <div class="flex gap-2">
          <input
            type="text"
            id="url-input"
            placeholder="https://your-site.com"
            class="bg-[#111] border border-gray-800 rounded-lg px-4 py-3 font-mono text-sm flex-1 focus:border-green-accent focus:outline-none text-gray-200"
          />
          <button
            id="check-btn"
            class="bg-green-accent text-black font-mono font-bold px-6 py-3 rounded-lg hover:bg-green-400 transition-colors cursor-pointer shrink-0"
          >
            Check
          </button>
        </div>
        <p id="jk-text" class="text-gray-600 text-xs mt-3 opacity-0 transition-all duration-500 translate-y-2">
          Just kidding — it runs locally. <a href="https://github.com/peaktwilight/vibecheck" target="_blank" rel="noopener" class="text-green-accent hover:underline">Clone the repo</a> and roast yourself.
        </p>
      </div>
    </section>

    <script>
      document.getElementById('check-btn')?.addEventListener('click', () => {
        const jk = document.getElementById('jk-text');
        if (jk) {
          jk.style.opacity = '1';
          jk.style.transform = 'translateY(0)';
        }
      });
      document.getElementById('url-input')?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          document.getElementById('check-btn')?.click();
        }
      });
    </script>

    <!-- ═══════════════ RED FLAGS ═══════════════ -->
    <section class="relative py-24 px-4">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-mono text-3xl sm:text-4xl font-bold text-white mb-4">
            Red flags it <span class="text-red-500">detects</span>
          </h2>
          <p class="text-gray-500 font-sans max-w-lg mx-auto">
            If your site has three or more of these, you might have a problem.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {redFlags.map((flag, i) => (
            <div class="group flex items-center gap-3 px-5 py-4 rounded-lg border border-gray-800/60 bg-[#111111]/50 hover:border-red-500/30 hover:bg-red-500/5 transition-all duration-300">
              <span class="text-xl shrink-0">{flag.icon}</span>
              <span class="text-sm text-gray-300 font-mono">{flag.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════ HOW IT WORKS ═══════════════ -->
    <section class="relative py-24 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-mono text-3xl sm:text-4xl font-bold text-white mb-4">
            How it <span class="text-green-accent">works</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {steps.map((step) => (
            <div class="relative text-center group">
              <div class="text-4xl mb-4">{step.icon}</div>
              <div class="font-mono text-xs text-green-accent/60 mb-2">{step.num}</div>
              <h3 class="font-mono text-lg font-bold text-white mb-2">{step.title}</h3>
              <p class="text-sm text-gray-500 font-sans leading-relaxed">{step.desc}</p>
            </div>
          ))}
        </div>

        <!-- Connector lines (desktop only) -->
        <div class="hidden md:flex justify-center -mt-[7.5rem] mb-12 pointer-events-none">
          <div class="flex items-center gap-0 w-full max-w-md mx-auto px-16">
            <div class="flex-1 border-t border-dashed border-gray-800"></div>
            <div class="px-3 text-gray-700 font-mono text-xs">&rarr;</div>
            <div class="flex-1 border-t border-dashed border-gray-800"></div>
            <div class="px-3 text-gray-700 font-mono text-xs">&rarr;</div>
            <div class="flex-1 border-t border-dashed border-gray-800"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════ VERDICTS ═══════════════ -->
    <section class="relative py-24 px-4">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-mono text-3xl sm:text-4xl font-bold text-white mb-4">
            The <span class="text-green-accent">verdicts</span>
          </h2>
          <p class="text-gray-500 font-sans max-w-lg mx-auto">
            Five tiers. No mercy.
          </p>
        </div>

        <div class="space-y-3">
          {verdicts.map((v) => (
            <div
              class="flex items-center gap-4 px-6 py-4 rounded-lg border font-mono transition-all duration-300 hover:scale-[1.02]"
              style={`border-color: ${v.border}; background: ${v.bg};`}
            >
              <div class="w-3 h-3 rounded-full shrink-0" style={`background: ${v.color};`}></div>
              <span class="text-sm sm:text-base font-bold tracking-wider" style={`color: ${v.color};`}>{v.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════ QUICK START ═══════════════ -->
    <section class="relative py-24 px-4">
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="font-mono text-3xl sm:text-4xl font-bold text-white mb-4">
            Quick <span class="text-green-accent">start</span>
          </h2>
        </div>

        <div class="rounded-lg border border-gray-800 bg-[#111111] overflow-hidden">
          <div class="flex items-center gap-2 px-4 py-3 bg-[#0d0d0d] border-b border-gray-800">
            <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
            <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
            <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
            <span class="ml-2 text-xs text-gray-500 font-mono">terminal</span>
          </div>
          <div class="p-6 font-mono text-sm space-y-1">
            <div><span class="text-gray-500"># Clone and build</span></div>
            <div><span class="text-green-accent">$</span> <span class="text-gray-200">git clone https://github.com/peaktwilight/vibecheck</span></div>
            <div><span class="text-green-accent">$</span> <span class="text-gray-200">cd vibecheck && npm install</span></div>
            <div><span class="text-green-accent">$</span> <span class="text-gray-200">npx playwright install chromium</span></div>
            <div><span class="text-green-accent">$</span> <span class="text-gray-200">npm run build</span></div>
            <div class="pt-3"><span class="text-gray-500"># Roast a website</span></div>
            <div><span class="text-green-accent">$</span> <span class="text-gray-200">node dist/cli.js https://your-site.com</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════ SHARE ═══════════════ -->
    <section class="relative py-24 px-4">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="font-mono text-3xl sm:text-4xl font-bold text-white mb-4">
          Share your <span class="text-green-accent">score</span>
        </h2>
        <p class="text-gray-500 font-sans mb-8">
          Roasted your site? Share the shame (or glory).
        </p>
        <div class="flex gap-4 justify-center">
          <a
            href="https://twitter.com/intent/tweet?text=My%20site%20got%20roasted%20by%20vibecheck%20%F0%9F%94%A5%20https://vibecheck.doruk.ch"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-5 py-3 rounded-lg border border-gray-800 bg-[#111] hover:border-green-accent/40 hover:bg-green-accent/5 transition-all duration-300 font-mono text-sm text-gray-300 hover:text-white"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Share on X
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════ FOOTER ═══════════════ -->
    <footer class="relative py-16 px-4 border-t border-gray-800/50">
      <div class="max-w-4xl mx-auto text-center">
        <p class="font-mono text-sm text-gray-600 mb-4">
          Built with spite for generic UIs.
        </p>
        <a
          href="https://github.com/peaktwilight/vibecheck"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-gray-500 hover:text-green-accent transition-colors font-mono text-sm"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          peaktwilight/vibecheck
        </a>
        <p class="font-mono text-xs text-gray-600 mt-6">
          Made by <a href="https://github.com/peaktwilight" target="_blank" rel="noopener" class="text-gray-400 hover:text-green-accent transition-colors">@peaktwilight</a>
          <span class="mx-2">&middot;</span>
          <a href="https://doruk.ch" target="_blank" rel="noopener" class="text-gray-400 hover:text-green-accent transition-colors">doruk.ch</a>
        </p>
      </div>
    </footer>
  </div>
</Layout>
