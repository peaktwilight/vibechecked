---
import Layout from '../layouts/Layout.astro';
import { Camera, Search, Flame, Palette, Layout as LayoutIcon, Type, Droplets, ShieldAlert, Sparkles, Github, Star, ExternalLink, ChevronDown, Copy, Check, Share2, Layers, Grid3x3, Smartphone, Moon, Circle, Fingerprint, Award } from 'lucide-astro';

const scores = [
  { label: 'Originality', value: 62, color: '#eab308' },
  { label: 'Layout', value: 35, color: '#ef4444' },
  { label: 'Typography', value: 55, color: '#eab308' },
  { label: 'Color', value: 58, color: '#eab308' },
  { label: 'Overall', value: 50, color: '#eab308' },
];

const redFlags = [
  { label: 'Purple gradients', icon: 'palette' },
  { label: 'Glassmorphism', icon: 'layers' },
  { label: 'Hero > Features > Pricing layout', icon: 'layout' },
  { label: 'Gradient text', icon: 'type' },
  { label: '"Trusted by" logo bars', icon: 'award' },
  { label: '3-column feature cards', icon: 'grid' },
  { label: 'Floating angled mockups', icon: 'smartphone' },
  { label: 'Dark mode + neon accents', icon: 'moon' },
  { label: 'Excessive rounded corners', icon: 'circle' },
];

const verdicts = [
  { label: 'CERTIFIED ORIGINAL', color: '#22c55e', bg: '#22c55e15', border: '#22c55e40' },
  { label: 'MOSTLY FRESH', color: '#86efac', bg: '#86efac15', border: '#86efac40' },
  { label: 'KINDA MID', color: '#eab308', bg: '#eab30815', border: '#eab30840' },
  { label: 'GENERIC AF', color: '#f97316', bg: '#f9731615', border: '#f9731640' },
  { label: 'VIBE-CODED CLONE', color: '#ef4444', bg: '#ef444415', border: '#ef444440' },
];
---

<Layout>
  <!-- ═══════════════ NAVBAR ═══════════════ -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
      <a href="/" class="font-mono text-lg font-bold text-white tracking-tight">
        vibe<span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-500">check</span>
      </a>
      <a
        href="https://github.com/peaktwilight/vibecheck"
        target="_blank"
        rel="noopener"
        class="text-gray-400 hover:text-white transition-colors"
        aria-label="GitHub"
      >
        <Github class="w-5 h-5" />
      </a>
    </div>
  </nav>
  <script>
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        navbar?.classList.add('bg-[#0a0a0a]/80', 'backdrop-blur-md', 'border-b', 'border-gray-800/50');
      } else {
        navbar?.classList.remove('bg-[#0a0a0a]/80', 'backdrop-blur-md', 'border-b', 'border-gray-800/50');
      }
    }, { passive: true });
  </script>

  <div class="noise">
    <!-- ═══════════════ HERO ═══════════════ -->
    <section class="relative min-h-screen flex flex-col items-center justify-center px-4 overflow-hidden">
      <!-- Subtle grid background -->
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(#22c55e 1px, transparent 1px), linear-gradient(90deg, #22c55e 1px, transparent 1px); background-size: 60px 60px;"></div>

      <!-- Glow effect -->
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-green-accent/5 rounded-full blur-[120px]"></div>

      <div class="relative z-10 text-center max-w-4xl mx-auto">
        <!-- Logo -->
        <h1 class="font-mono text-6xl sm:text-7xl md:text-8xl font-bold tracking-tighter text-white mb-4 animate-fade-in-up">
          vibe<span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-500">check</span>
        </h1>

        <!-- Tagline with pulsing dot -->
        <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-12 animate-fade-in-up delay-200 font-sans flex items-center justify-center gap-2">
          <span class="relative flex h-2.5 w-2.5 shrink-0">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-accent opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-accent"></span>
          </span>
          Is your UI actually good? Or just another vibe-coded clone?
        </p>

        <!-- Terminal -->
        <div class="animate-fade-in-up delay-400 w-full max-w-2xl mx-auto">
          <div class="rounded-xl border border-gray-800 bg-[#111111] shadow-2xl shadow-black/50 overflow-hidden text-left">
            <!-- Terminal header -->
            <div class="flex items-center gap-2 px-4 py-2.5 bg-[#0d0d0d] border-b border-gray-800">
              <div class="flex items-center gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></div>
              </div>
              <div class="flex-1 mx-8">
                <div class="bg-[#1a1a1a] rounded-md px-3 py-1 text-center">
                  <span class="text-[10px] text-gray-500 font-mono">vibecheck vercel.com</span>
                </div>
              </div>
              <div class="w-[52px]"></div>
            </div>

            <!-- Terminal body -->
            <div class="p-4 sm:p-6 font-mono text-sm leading-relaxed space-y-3">
              <!-- Command -->
              <div class="text-gray-500">
                <span class="text-green-accent">$</span> vibecheck vercel.com
              </div>

              <div class="text-gray-600 text-xs">Analyzing screenshot...</div>

              <!-- Score bars -->
              <div class="space-y-2 pt-2">
                {scores.map((score, i) => (
                  <div class="flex items-center gap-3">
                    <span class="text-gray-500 text-xs w-24 text-right">{score.label}</span>
                    <div class="flex-1 h-4 bg-gray-800/50 rounded-sm overflow-hidden relative">
                      <div
                        class="h-full rounded-sm animate-fill-bar"
                        style={`width: ${score.value}%; background: ${score.color}; animation-delay: ${0.8 + i * 0.2}s;`}
                      ></div>
                    </div>
                    <span class="text-xs w-8" style={`color: ${score.color}`}>{score.value}</span>
                  </div>
                ))}
              </div>

              <!-- Roast -->
              <div class="pt-3 border-t border-gray-800/50">
                <span class="text-gray-600 text-xs">ROAST:</span>
                <p class="text-gray-300 text-xs mt-1 leading-relaxed">
                  "Vercel really said 'we're the AI Cloud' and then slapped a triangle on a rainbow gradient like a Pink Floyd album cover designed by a CS major who just discovered CSS blend modes."
                </p>
              </div>

              <!-- Verdict -->
              <div class="flex items-center gap-3 pt-2">
                <span class="text-gray-600 text-xs">VERDICT:</span>
                <span class="text-yellow-400 font-bold text-sm tracking-wider">KINDA MID</span>
              </div>

              <!-- Vibe-coded probability -->
              <div class="flex items-center gap-3">
                <span class="text-gray-600 text-xs">VIBE-CODED:</span>
                <span class="text-yellow-400 text-sm">38%</span>
                <div class="flex-1 h-1.5 bg-gray-800 rounded-full overflow-hidden">
                  <div class="h-full bg-yellow-400/60 rounded-full animate-fill-bar" style="width: 38%; animation-delay: 2s;"></div>
                </div>
              </div>

              <!-- Cursor -->
              <div class="pt-1">
                <span class="text-green-accent">$</span>
                <span class="inline-block w-2 h-4 bg-green-accent ml-1 animate-blink"></span>
              </div>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="mt-10 animate-fade-in-up delay-700">
          <a
            href="https://github.com/peaktwilight/vibecheck"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 bg-green-accent text-[#0a0a0a] font-mono font-semibold text-sm rounded-md hover:bg-green-400 transition-colors duration-200"
          >
            <Github class="w-5 h-5" />
            Get Started
          </a>
        </div>

        <!-- GitHub star line -->
        <p class="text-gray-500 font-mono text-sm mt-4 animate-fade-in-up delay-800 flex items-center justify-center gap-2">
          <a href="https://github.com/peaktwilight/vibecheck" target="_blank" rel="noopener" class="hover:text-green-accent transition-colors inline-flex items-center gap-1">
            <Star class="w-3.5 h-3.5" />
            Star on GitHub
          </a>
          <span>&middot;</span>
          <span>Free &amp; open source</span>
          <span>&middot;</span>
          <span>MIT License</span>
        </p>
      </div>

      <!-- Scroll indicator -->
      <a href="#try-it" class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce opacity-30 cursor-pointer">
        <ChevronDown class="w-5 h-5 text-gray-500" />
      </a>
    </section>

    <!-- ═══════════════ TRY IT ═══════════════ -->
    <section id="try-it" class="relative py-24 px-4">
      <div class="max-w-xl mx-auto text-center">
        <h2 class="font-mono text-3xl sm:text-4xl font-bold text-white mb-6">
          Think YOUR site would <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-500">pass</span>?
        </h2>
        <div class="flex gap-2">
          <input
            type="text"
            id="url-input"
            placeholder="https://your-site.com"
            class="bg-[#111] border border-gray-800 rounded-lg px-4 py-3 font-mono text-sm flex-1 focus:border-green-accent focus:outline-none text-gray-200"
          />
          <button
            id="check-btn"
            class="bg-green-accent text-black font-mono font-bold px-6 py-3 rounded-lg hover:bg-green-400 transition-colors cursor-pointer shrink-0"
          >
            Check
          </button>
        </div>
        <p id="jk-text" class="text-gray-600 text-xs mt-3 opacity-0 transition-all duration-500 translate-y-2">
          Just kidding — it runs locally. <a href="https://github.com/peaktwilight/vibecheck" target="_blank" rel="noopener" class="text-green-accent hover:underline">Clone the repo</a> and roast yourself.
        </p>
      </div>
    </section>

    <script>
      document.getElementById('check-btn')?.addEventListener('click', () => {
        const jk = document.getElementById('jk-text');
        if (jk) {
          jk.style.opacity = '1';
          jk.style.transform = 'translateY(0)';
        }
      });
      document.getElementById('url-input')?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          document.getElementById('check-btn')?.click();
        }
      });
    </script>

    <!-- ═══════════════ HOW IT WORKS ═══════════════ -->
    <section class="relative py-28 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-mono text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4">
            How it <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-500">works</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="relative text-center group">
            <div class="flex items-center justify-center mb-4">
              <div class="w-14 h-14 rounded-xl bg-green-accent/10 border border-green-accent/20 flex items-center justify-center group-hover:bg-green-accent/15 transition-colors">
                <Camera class="w-6 h-6 text-green-accent" />
              </div>
            </div>
            <div class="font-mono text-xs text-green-accent/60 mb-2">01</div>
            <h3 class="font-mono text-lg font-bold text-white mb-2">Screenshot</h3>
            <p class="text-base text-gray-500 font-sans leading-relaxed">Point it at any URL. Puppeteer captures a full-page screenshot.</p>
          </div>

          <div class="relative text-center group">
            <div class="flex items-center justify-center mb-4">
              <div class="w-14 h-14 rounded-xl bg-green-accent/10 border border-green-accent/20 flex items-center justify-center group-hover:bg-green-accent/15 transition-colors">
                <Search class="w-6 h-6 text-green-accent" />
              </div>
            </div>
            <div class="font-mono text-xs text-green-accent/60 mb-2">02</div>
            <h3 class="font-mono text-lg font-bold text-white mb-2">Analyze</h3>
            <p class="text-base text-gray-500 font-sans leading-relaxed">Claude examines every pixel for design patterns, cliches, and red flags.</p>
          </div>

          <div class="relative text-center group">
            <div class="flex items-center justify-center mb-4">
              <div class="w-14 h-14 rounded-xl bg-green-accent/10 border border-green-accent/20 flex items-center justify-center group-hover:bg-green-accent/15 transition-colors">
                <Flame class="w-6 h-6 text-green-accent" />
              </div>
            </div>
            <div class="font-mono text-xs text-green-accent/60 mb-2">03</div>
            <h3 class="font-mono text-lg font-bold text-white mb-2">Roast</h3>
            <p class="text-base text-gray-500 font-sans leading-relaxed">Get brutally honest scores, a roast, and your vibe-coded probability.</p>
          </div>
        </div>

        <!-- Connector lines (desktop only) -->
        <div class="hidden md:flex justify-center -mt-[10rem] mb-12 pointer-events-none">
          <div class="flex items-center gap-0 w-full max-w-md mx-auto px-16">
            <div class="flex-1 border-t border-dashed border-gray-800"></div>
            <div class="px-3 text-gray-700 font-mono text-xs">&rarr;</div>
            <div class="flex-1 border-t border-dashed border-gray-800"></div>
            <div class="px-3 text-gray-700 font-mono text-xs">&rarr;</div>
            <div class="flex-1 border-t border-dashed border-gray-800"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════ RED FLAGS ═══════════════ -->
    <section class="relative py-28 px-4">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-mono text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4">
            Red flags it <span class="text-red-500">detects</span>
          </h2>
          <p class="text-gray-500 font-sans max-w-lg mx-auto text-base mb-4">
            If your site has three or more of these, you might have a problem.
          </p>
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-red-500/10 border border-red-500/20 text-red-400 text-xs font-mono">
            <ShieldAlert class="w-3.5 h-3.5" />
            9 red flags we check for
          </span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {redFlags.map((flag) => (
            <div class="group flex items-center gap-3 px-5 py-4 rounded-lg border border-gray-800/60 bg-[#111111]/50 hover:border-red-500/40 hover:bg-red-500/5 hover:shadow-[0_0_20px_-5px_rgba(239,68,68,0.15)] transition-all duration-300">
              <div class="shrink-0 text-red-500/70 group-hover:text-red-500 transition-colors">
                {flag.icon === 'palette' && <Palette class="w-5 h-5" />}
                {flag.icon === 'layers' && <Layers class="w-5 h-5" />}
                {flag.icon === 'layout' && <LayoutIcon class="w-5 h-5" />}
                {flag.icon === 'type' && <Type class="w-5 h-5" />}
                {flag.icon === 'award' && <Award class="w-5 h-5" />}
                {flag.icon === 'grid' && <Grid3x3 class="w-5 h-5" />}
                {flag.icon === 'smartphone' && <Smartphone class="w-5 h-5" />}
                {flag.icon === 'moon' && <Moon class="w-5 h-5" />}
                {flag.icon === 'circle' && <Circle class="w-5 h-5" />}
              </div>
              <span class="text-sm text-gray-300 font-mono">{flag.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════ SOCIAL PROOF ═══════════════ -->
    <section class="relative py-28 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="font-mono text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4">
            Built for developers who <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-500">care about design</span>
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
          <div class="py-6">
            <div class="text-4xl font-bold font-mono text-green-accent mb-2">5</div>
            <div class="text-sm text-gray-500">scoring dimensions</div>
          </div>
          <div class="py-6">
            <div class="text-4xl font-bold font-mono text-green-accent mb-2">11</div>
            <div class="text-sm text-gray-500">red flags detected</div>
          </div>
          <div class="py-6">
            <div class="text-4xl font-bold font-mono text-green-accent mb-2">1</div>
            <div class="text-sm text-gray-500">savage roast per URL</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════ VERDICTS ═══════════════ -->
    <section class="relative py-28 px-4">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-mono text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4">
            The <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-500">verdicts</span>
          </h2>
          <p class="text-gray-500 font-sans max-w-lg mx-auto text-base">
            Five tiers. No mercy.
          </p>
        </div>

        <div class="space-y-3">
          {verdicts.map((v) => (
            <div
              class="flex items-center gap-4 px-6 py-4 rounded-lg border font-mono transition-all duration-300 hover:scale-[1.02]"
              style={`border-color: ${v.border}; background: ${v.bg};`}
            >
              <div class="w-3 h-3 rounded-full shrink-0" style={`background: ${v.color};`}></div>
              <span class="text-sm sm:text-base font-bold tracking-wider" style={`color: ${v.color};`}>{v.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════ QUICK START ═══════════════ -->
    <section class="relative py-28 px-4">
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="font-mono text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4">
            Quick <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-500">start</span>
          </h2>
        </div>

        <div class="rounded-xl border border-gray-800 bg-[#111111] overflow-hidden">
          <div class="flex items-center gap-2 px-4 py-2.5 bg-[#0d0d0d] border-b border-gray-800">
            <div class="flex items-center gap-1.5">
              <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></div>
            </div>
            <div class="flex-1 mx-8">
              <div class="bg-[#1a1a1a] rounded-md px-3 py-1 text-center">
                <span class="text-[10px] text-gray-500 font-mono">terminal</span>
              </div>
            </div>
            <button
              id="copy-btn"
              class="text-gray-500 hover:text-white transition-colors p-1 rounded cursor-pointer"
              title="Copy to clipboard"
            >
              <Copy class="w-4 h-4 copy-icon" />
              <Check class="w-4 h-4 check-icon hidden text-green-accent" />
            </button>
          </div>
          <div class="p-6 font-mono text-sm space-y-1">
            <div><span class="text-gray-500"># Clone and build</span></div>
            <div><span class="text-green-accent">$</span> <span class="text-gray-200">git clone https://github.com/peaktwilight/vibecheck</span></div>
            <div><span class="text-green-accent">$</span> <span class="text-gray-200">cd vibecheck && npm install</span></div>
            <div><span class="text-green-accent">$</span> <span class="text-gray-200">npx playwright install chromium</span></div>
            <div><span class="text-green-accent">$</span> <span class="text-gray-200">npm run build</span></div>
            <div class="pt-3"><span class="text-gray-500"># Roast a website</span></div>
            <div><span class="text-green-accent">$</span> <span class="text-gray-200">node dist/cli.js https://your-site.com</span></div>
          </div>
        </div>
      </div>
    </section>

    <script>
      document.getElementById('copy-btn')?.addEventListener('click', function() {
        navigator.clipboard.writeText('git clone https://github.com/peaktwilight/vibecheck && cd vibecheck && npm install && npx playwright install chromium && npm run build');
        const copyIcon = this.querySelector('.copy-icon');
        const checkIcon = this.querySelector('.check-icon');
        if (copyIcon && checkIcon) {
          copyIcon.classList.add('hidden');
          checkIcon.classList.remove('hidden');
          setTimeout(() => {
            copyIcon.classList.remove('hidden');
            checkIcon.classList.add('hidden');
          }, 2000);
        }
      });
    </script>

    <!-- ═══════════════ SHARE ═══════════════ -->
    <section class="relative py-28 px-4">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="font-mono text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4">
          Share your <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-500">score</span>
        </h2>
        <p class="text-gray-500 font-sans mb-8 text-base">
          Roasted your site? Share the shame (or glory).
        </p>
        <div class="flex gap-4 justify-center">
          <a
            href="https://twitter.com/intent/tweet?text=My%20site%20got%20roasted%20by%20vibecheck%20%F0%9F%94%A5%20https://vibecheck.doruk.ch"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-5 py-3 rounded-lg border border-gray-800 bg-[#111] hover:border-green-accent/40 hover:bg-green-accent/5 transition-all duration-300 font-mono text-sm text-gray-300 hover:text-white"
          >
            <Share2 class="w-4 h-4" />
            Share on X
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════ FOOTER ═══════════════ -->
    <footer class="relative py-16 px-4">
      <!-- Gradient top border -->
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-green-accent/30 to-transparent"></div>

      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center sm:items-start justify-between gap-8">
        <!-- Left: Logo + tagline -->
        <div class="text-center sm:text-left">
          <div class="font-mono text-lg font-bold text-white tracking-tight mb-2">
